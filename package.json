{
  "name": "gym-ease-nextjs",
  "version": "0.1.0",
  "private": true,
  "author": {
    "name": "Parallax Machine Inc",
    "email": "parallaxmachineinc@gmail.com"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron-dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-build": "next build && electron-builder --win"
  },
  "build": {
    "appId": "com.gymease.app",
    "productName": "Gym Ease",
    "win": {
      "target": "nsis"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      },
      {
        "from": ".next/static",
        "to": "standalone/.next/static"
      },
      {
        "from": "public",
        "to": "standalone/public"
      },
      {
        "from": "node_modules/better-sqlite3",
        "to": "standalone/node_modules/better-sqlite3"
      },
      {
        "from": "node_modules/bcryptjs",
        "to": "standalone/node_modules/bcryptjs"
      }
    ],
    "npmRebuild": false
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.26.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.562.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.6.0",
    "sonner": "^2.0.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.2",
    "@eslint/js": "^9.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/eslint__js": "^8.42.3",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "~10",
    "concurrently": "^9.1.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "eslint": "^9.21.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "~8",
    "tailwindcss": "~3",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.0.0",
    "wait-on": "^7.2.0"
  }
}